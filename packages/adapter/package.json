{
  "name": "elysia-sveltekit",
  "version": "1.0.1",
  "description": "Server hook adapter bridging the Elysia web framework with SvelteKit",
  "keywords": [
    "adapter",
    "bun",
    "elysia",
    "hook",
    "server",
    "sveltekit"
  ],
  "homepage": "https://github.com/pyoner/elysia-sveltekit#readme",
  "bugs": {
    "url": "https://github.com/pyoner/elysia-sveltekit/issues"
  },
  "license": "MIT",
  "author": "Askar Yusupov <devex.soft@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyoner/elysia-sveltekit.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@sveltejs/kit": "^2.0.0",
    "bun-types": "latest",
    "elysia": "1.2.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "elysia": "^1.2"
  }
}

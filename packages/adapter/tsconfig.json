{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": false,
    "declaration": true,
    "outDir": "dist",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["bun-types"]
  },
  "include": ["src"]
}
